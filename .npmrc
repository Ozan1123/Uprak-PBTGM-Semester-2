# ─── pnpm Security Configuration ─────────────────────────────────
# Hanya package yang sudah di-approve yang boleh jalankan build scripts
# Daftar approved ada di package.json > pnpm.onlyBuiltDependencies
onlyBuiltDependencies=true

# Gunakan exact versions saat pnpm add (tanpa ^ atau ~)
save-exact=true

# Strict peer dependencies — gagal jika ada mismatch
strict-peer-dependencies=false

# Verifikasi integritas tarball yang diunduh
verify-store-integrity=true
