{
  "name": "widget-keuangan",
  "version": "1.0.0",
  "description": "Widget Pengelolaan Keuangan Desktop",
  "main": "src/main/main.js",
  "type": "commonjs",
  "scripts": {
    "dev:renderer": "vite --config vite.config.mjs",
    "dev:electron": "electron .",
    "dev": "concurrently -k \"pnpm run dev:renderer\" \"wait-on http://localhost:5173 && pnpm run dev:electron\"",
    "build:renderer": "vite build --config vite.config.mjs",
    "dist": "pnpm run build:renderer && electron-builder",
    "start": "electron .",
    "audit": "pnpm audit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "better-sqlite3": "12.10.0",
    "lucide-react": "0.511.0",
    "motion": "12.12.1",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@electron/rebuild": "4.0.4",
    "@tailwindcss/vite": "4.1.7",
    "@vitejs/plugin-react": "4.5.2",
    "concurrently": "9.1.2",
    "electron": "35.7.5",
    "electron-builder": "26.8.1",
    "tailwindcss": "4.1.7",
    "vite": "6.3.5",
    "wait-on": "8.0.3"
  },
  "build": {
    "appId": "com.example.myapp",
    "win": {
      "target": "nsis"
    },
    "files": [
      "renderer-dist/**/*",
      "src/main/**/*",
      "package.json"
    ]
  }
}
