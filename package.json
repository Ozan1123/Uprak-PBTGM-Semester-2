    "@vitejs/plugin-react": "^4.5.2",
    "concurrently": "^9.1.2",
    "electron": "^35.1.2",
    "tailwindcss": "^4.1.7",
    "vite": "^6.3.5",
    "wait-on": "^8.0.3"
  }
